# AI Office / Axl.ai — example environment file.
# Copy to `.env` for local development. Production values live on the VPS.

# ──────────────────────────────────────────────────────────────────────────
# Core / legacy AI Office
# ──────────────────────────────────────────────────────────────────────────

# Where spawned-project files land. Defaults to ./projects.
PROJECTS_DIR=

# LLM provider keys. None required to boot, but the manager will fail to call
# any provider whose key is missing.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Stage 6 — Axl.ai investment intelligence
# ──────────────────────────────────────────────────────────────────────────

# UK Companies House — optional. When unset the companies_house connector
# silently returns no rows.
COMPANIES_HOUSE_API_KEY=

# Analytics service (FastAPI) — startup-metrics calculator. Workflow falls back
# to a local in-process calculator when this is unreachable.
AXL_ANALYTICS_URL=http://localhost:8765

# Outbound HTTP identity. SEC EDGAR specifically asks for a descriptive UA +
# From header; setting these in production is strongly recommended.
AXL_HTTP_USER_AGENT=Axl.ai/0.6 (+https://github.com/FatCatAnalytics/ai-office; contact: ops@axl.ai)
AXL_HTTP_FROM=ops@axl.ai

# SEC-specific override for the From header. Falls back to AXL_HTTP_FROM.
AXL_SEC_FROM=

# How long the SEC company_tickers.json in-memory cache is reused before
# being refetched. Default: 12h.
AXL_SEC_TICKER_TTL_MS=43200000

# Outer wall-clock limit (ms) for each connector inside gatherPublicEvidence.
# A single connector cannot exceed this regardless of its own network timeout.
AXL_CONNECTOR_WALL_CLOCK_MS=20000

# ──────────────────────────────────────────────────────────────────────────
# Stage 6.10 — Perplexity research provider (backup / fallback)
# ──────────────────────────────────────────────────────────────────────────
# When set, research-capable agents (deep-search, source-discovery,
# annual-reports-search, industry-research, doc-specialist,
# data-val-specialist) gain a `perplexity_research` tool, the public-
# evidence pipeline runs an additional Perplexity connector that contributes
# a synthesis + cited sources to startup diligence runs, AND the Tavily
# search/extract tools fall back to Perplexity automatically when Tavily
# hits a quota / rate-limit (HTTP 4xx, including the observed 433) or
# returns zero usable results.
#
# Leaving these unset is safe — every code path degrades to the existing
# Tavily-only behaviour without raising. If Tavily fails and Perplexity is
# unset, the Stage 6.9 fail-closed gate will still block publishable output
# (rather than fabricating sources) and the diagnostic message will
# recommend configuring this fallback.
#
# Get a key from https://www.perplexity.ai/settings/api . The key is read
# from the environment only; never paste it into client code or commit it.
# Verify wiring with `curl http://localhost:5000/api/integrations/perplexity`
# — the endpoint returns `{configured: true|false, …}` without leaking the key.
PERPLEXITY_API_KEY=
# Optional model override. Defaults to "sonar" (Perplexity's web-research
# Sonar tier). Other valid values include "sonar-pro" and the deep-research
# Sonar variants — refer to the Perplexity docs for the current list.
PERPLEXITY_MODEL=
# Optional API base URL override. Defaults to https://api.perplexity.ai .
PERPLEXITY_BASE_URL=
# Optional per-request wall-clock timeout in milliseconds (1000–120000).
# Defaults to 25000.
PERPLEXITY_TIMEOUT_MS=
