# AI Office / Axl.ai — example environment file.
# Copy to `.env` for local development. Production values live on the VPS.

# ──────────────────────────────────────────────────────────────────────────
# Core / legacy AI Office
# ──────────────────────────────────────────────────────────────────────────

# Where spawned-project files land. Defaults to ./projects.
PROJECTS_DIR=

# LLM provider keys. None required to boot, but the manager will fail to call
# any provider whose key is missing.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
KIMI_API_KEY=
DEEPSEEK_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Stage 6 — Axl.ai investment intelligence
# ──────────────────────────────────────────────────────────────────────────

# UK Companies House — optional. When unset the companies_house connector
# silently returns no rows.
COMPANIES_HOUSE_API_KEY=

# Analytics service (FastAPI) — startup-metrics calculator. Workflow falls back
# to a local in-process calculator when this is unreachable.
AXL_ANALYTICS_URL=http://localhost:8765

# Outbound HTTP identity. SEC EDGAR specifically asks for a descriptive UA +
# From header; setting these in production is strongly recommended.
AXL_HTTP_USER_AGENT=Axl.ai/0.6 (+https://github.com/FatCatAnalytics/ai-office; contact: ops@axl.ai)
AXL_HTTP_FROM=ops@axl.ai

# SEC-specific override for the From header. Falls back to AXL_HTTP_FROM.
AXL_SEC_FROM=

# How long the SEC company_tickers.json in-memory cache is reused before
# being refetched. Default: 12h.
AXL_SEC_TICKER_TTL_MS=43200000

# Outer wall-clock limit (ms) for each connector inside gatherPublicEvidence.
# A single connector cannot exceed this regardless of its own network timeout.
AXL_CONNECTOR_WALL_CLOCK_MS=20000
